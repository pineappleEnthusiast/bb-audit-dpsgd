#!/bin/bash
#SBATCH -J grad_bw_attack
#SBATCH -o status/grad_bw_attack_%A_%a.o
#SBATCH -e status/grad_bw_attack_%A_%a.e
#SBATCH -p gh
#SBATCH -N 5
#SBATCH --ntasks-per-node=1
#SBATCH -t 10:00:00
#SBATCH -A ASC25081
#SBATCH --array=0-1

module load cuda/12.4

set -e
cd $SCRATCH
eval "$(conda shell.bash hook)"
conda activate bb_audit_dpsgd
cd bb-audit-dpsgd

mkdir -p status

# ─── Shared hyperparameters ───
DATA_NAME="mnist"
MODEL_NAME="cnn"
N_REPS=400
N_EPOCHS=100
LR=3
MAX_GRAD_NORM=1.0
EPSILON=10.0
DELTA=1e-5
BATCH_SIZE=4000
BLOCK_SIZE=4000
N_CANARIES=500
SEED=0
DEFENSE_K=5
DEFENSE_SCORE_FN="grad_norm_unclipped"
DEFENSE_SCORE_NORM="linf"

OUTPUT_DIR="grad_bandwidth_attack_${DATA_NAME}_eps${EPSILON}"
CANARY_PT="${OUTPUT_DIR}/gradient_space_canaries.pt"

# ─── Step 0 (run once): Generate gradient-bandwidth canaries ───
# Only task 0 generates; task 1 waits for the file.
if [ "${SLURM_ARRAY_TASK_ID}" -eq 0 ]; then
    if [ ! -f "${CANARY_PT}" ]; then
        echo "=========================================="
        echo "Generating gradient-bandwidth canaries"
        echo "=========================================="
        python generate_gradient_bandwidth_attack.py \
            --data_name "${DATA_NAME}" \
            --model_name "${MODEL_NAME}" \
            --n_epochs "${N_EPOCHS}" \
            --lr "${LR}" \
            --batch_size "${BATCH_SIZE}" \
            --max_grad_norm "${MAX_GRAD_NORM}" \
            --epsilon "${EPSILON}" \
            --delta "${DELTA}" \
            --defense_k "${DEFENSE_K}" \
            --n_canaries "${N_CANARIES}" \
            --seed "${SEED}" \
            --device cuda:0 \
            --output_dir "${OUTPUT_DIR}"
    else
        echo "Canary file already exists: ${CANARY_PT}"
    fi
else
    # Task 1: wait for the canary file to appear (generated by task 0)
    echo "Waiting for canary file: ${CANARY_PT}"
    while [ ! -f "${CANARY_PT}" ]; do sleep 10; done
    echo "Canary file found."
fi

# ─── Step 1: Audit (array index selects defense on/off) ───
experiments=(
    "false|${OUTPUT_DIR}/audit_no_defense"
    "true|${OUTPUT_DIR}/audit_defense"
)

IFS='|' read -r DEFENSE OUT_NAME <<< "${experiments[$SLURM_ARRAY_TASK_ID]}"

DEFENSE_ARGS=""
if [ "${DEFENSE}" = "true" ]; then
    DEFENSE_ARGS="--defense --defense_k ${DEFENSE_K} --defense_score_fn ${DEFENSE_SCORE_FN} --defense_score_norm ${DEFENSE_SCORE_NORM}"
fi

echo "=========================================="
echo "Task ${SLURM_ARRAY_TASK_ID}: DEFENSE=${DEFENSE}"
echo "Dataset: ${DATA_NAME}  Model: ${MODEL_NAME}  ε=${EPSILON}"
echo "N_CANARIES: ${N_CANARIES}  Score: hot_param"
echo "Output: ${OUT_NAME}"
echo "=========================================="

srun --ntasks=$SLURM_NTASKS --nodes=$SLURM_JOB_NUM_NODES bash -c '
  MASTER_ADDR=$(scontrol show hostnames $SLURM_JOB_NODELIST | head -n 1);
  MASTER_PORT=$((29500 + '"${SLURM_ARRAY_TASK_ID}"'));
  torchrun --nnodes=$SLURM_JOB_NUM_NODES --nproc_per_node=1 \
    --rdzv_backend=c10d \
    --rdzv_endpoint=${MASTER_ADDR}:${MASTER_PORT} \
    parallel_audit_multi_canary.py \
    --data_name '"${DATA_NAME}"' \
    --model_name '"${MODEL_NAME}"' \
    --n_reps '"${N_REPS}"' \
    --n_epochs '"${N_EPOCHS}"' \
    --lr '"${LR}"' \
    --max_grad_norm '"${MAX_GRAD_NORM}"' \
    --epsilon '"${EPSILON}"' \
    --delta '"${DELTA}"' \
    --batch_size '"${BATCH_SIZE}"' \
    --block_size '"${BLOCK_SIZE}"' \
    --n_canaries '"${N_CANARIES}"' \
    --sampling poisson \
    --holdout_audit \
    --seed '"${SEED}"' \
    --fixed_init \
    --target_type gradient_space_canary \
    --gradient_space_canary_pt '"${CANARY_PT}"' \
    --gradient_space_score_fn hot_param \
    '"${DEFENSE_ARGS}"' \
    --out '"${OUT_NAME}"''

echo "Task ${SLURM_ARRAY_TASK_ID} completed: ${OUT_NAME}"
